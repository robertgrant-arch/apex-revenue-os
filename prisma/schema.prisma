// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

enum Plan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum Vertical {
  MEDICARE
  AUTO
  HOME_SERVICES
  INSURANCE
  LEGAL
}

enum IntentLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum LeadStatus {
  NEW_LEAD
  IN_SEQUENCE
  NURTURE
  APPOINTMENT_SET
  CLOSED_WON
  DISQUALIFIED
}

enum LeadSource {
  FACEBOOK
  GOOGLE
  TIKTOK
  EMAIL
  REFERRAL
  LINKEDIN
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum CreativeType {
  IMAGE
  VIDEO
  COPY
  LANDING_PAGE
}

enum CreativeStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  LIVE
}

enum ComplianceStatus {
  PENDING
  PASSED
  FLAGGED
  BLOCKED
}

enum AgentType {
  LEAD_QUALIFIER
  APPOINTMENT_SETTER
  FOLLOW_UP
  COMPLIANCE_REVIEWER
  CREATIVE_GENERATOR
}

enum AgentStatus {
  ACTIVE
  PAUSED
  TRAINING
}

enum WorkflowStatus {
  ACTIVE
  PAUSED
  DRAFT
}

enum FlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FlagStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum ExperimentStatus {
  RUNNING
  COMPLETED
  PAUSED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  leads        Lead[]
  campaigns    Campaign[]
  creatives    Creative[]
  agents       Agent[]
  workflows    Workflow[]
  activities   Activity[]
  appointments Appointment[]
  experiments  Experiment[]

  @@index([slug])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         Role     @default(AGENT)
  avatar       String?
  orgId        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org                  Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedLeads        Lead[]          @relation("AssignedLeads")
  assignedAppointments Appointment[]   @relation("AssignedAppointments")
  resolvedFlags        ComplianceFlag[] @relation("ResolvedFlags")
  activities           Activity[]
  accounts             Account[]
  sessions             Session[]

  @@index([orgId])
  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id           String      @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  score        Int         @default(0)
  vertical     Vertical
  intent       IntentLevel @default(LOW)
  status       LeadStatus  @default(NEW_LEAD)
  source       LeadSource
  notes        String?     @db.Text
  assignedToId String?
  orgId        String
  metadata     Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  assignedTo   User?        @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  activities   Activity[]
  appointments Appointment[]

  @@index([orgId])
  @@index([assignedToId])
  @@index([status])
  @@index([vertical])
  @@index([intent])
  @@index([source])
  @@index([score])
  @@index([createdAt])
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  status      CampaignStatus @default(DRAFT)
  channel     String
  budget      Float
  spend       Float          @default(0)
  leadsCount  Int            @default(0)
  conversions Int            @default(0)
  startDate   DateTime?
  endDate     DateTime?
  orgId       String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creatives Creative[]

  @@index([orgId])
  @@index([status])
  @@index([channel])
  @@index([startDate])
  @@index([endDate])
}

model Creative {
  id               String           @id @default(cuid())
  name             String
  type             CreativeType
  status           CreativeStatus   @default(DRAFT)
  channel          String
  headline         String?
  body             String?          @db.Text
  ctaText          String?
  complianceStatus ComplianceStatus @default(PENDING)
  predictedCtr     Float?
  impressions      Int              @default(0)
  clicks           Int              @default(0)
  campaignId       String?
  orgId            String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  campaign        Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  complianceFlags ComplianceFlag[]
  experimentsAsA  Experiment[]     @relation("VariantA")
  experimentsAsB  Experiment[]     @relation("VariantB")

  @@index([orgId])
  @@index([campaignId])
  @@index([status])
  @@index([type])
  @@index([complianceStatus])
}

model Agent {
  id             String      @id @default(cuid())
  name           String
  type           AgentType
  status         AgentStatus @default(TRAINING)
  description    String?     @db.Text
  config         Json        @default("{}")
  successRate    Float       @default(0)
  tasksCompleted Int         @default(0)
  orgId          String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([type])
  @@index([status])
}

model Workflow {
  id             String         @id @default(cuid())
  name           String
  trigger        String
  steps          Json           @default("[]")
  status         WorkflowStatus @default(DRAFT)
  executionCount Int            @default(0)
  lastRunAt      DateTime?
  orgId          String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
  @@index([trigger])
}

model ComplianceFlag {
  id           String       @id @default(cuid())
  creativeId   String
  rule         String
  severity     FlagSeverity
  description  String       @db.Text
  status       FlagStatus   @default(OPEN)
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  creative   Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  resolvedBy User?    @relation("ResolvedFlags", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([creativeId])
  @@index([resolvedById])
  @@index([status])
  @@index([severity])
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  description String   @db.Text
  leadId      String?
  userId      String?
  orgId       String
  createdAt   DateTime @default(now())

  lead Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([leadId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Appointment {
  id           String            @id @default(cuid())
  leadId       String
  scheduledAt  DateTime
  status       AppointmentStatus @default(SCHEDULED)
  notes        String?           @db.Text
  assignedToId String?
  orgId        String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  lead       Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User?        @relation("AssignedAppointments", fields: [assignedToId], references: [id], onDelete: SetNull)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([leadId])
  @@index([assignedToId])
  @@index([status])
  @@index([scheduledAt])
}

model Experiment {
  id           String           @id @default(cuid())
  name         String
  variantAId   String
  variantBId   String
  status       ExperimentStatus @default(RUNNING)
  winner       String?
  startDate    DateTime?
  endDate      DateTime?
  impressionsA Int              @default(0)
  impressionsB Int              @default(0)
  clicksA      Int              @default(0)
  clicksB      Int              @default(0)
  orgId        String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  variantA Creative     @relation("VariantA", fields: [variantAId], references: [id], onDelete: Restrict)
  variantB Creative     @relation("VariantB", fields: [variantBId], references: [id], onDelete: Restrict)
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
  @@index([variantAId])
  @@index([variantBId])
  @@index([startDate])
  @@index([endDate])
}
